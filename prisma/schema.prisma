// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  phone     String?
  country   String?   // e.g., "Egypt", "KSA"
  role      Role      @default(USER)
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ads              Ad[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

enum Role {
  USER
  ADMIN
}

enum VehicleType {
  CAR
  MOTORCYCLE
}

enum Condition {
  NEW
  USED
}

enum AdStatus {
  ACTIVE
  INACTIVE
  SOLD
}

// Scraped catalog vehicle for general specs and prices comparison
model CatalogVehicle {
  id          Int         @id @default(autoincrement())
  type        VehicleType
  make        String      // e.g., "Toyota"
  modelName   String      // e.g., "Corolla"
  year        Int
  price       Float?      // Market price
  description String?
  specs       Json?       // Technical specs (engine size, horsepower, etc)
  images      String[]
  country     String
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// User posted ads
model Ad {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  price       Float
  type        VehicleType
  make        String
  modelName   String
  year        Int
  mileage     Int?
  condition   Condition
  country     String
  images      String[]
  status      AdStatus    @default(ACTIVE)

  userId      Int
  owner       User        @relation(fields: [userId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  messages    Message[]
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  
  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  
  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  adId       Int
  ad         Ad       @relation(fields: [adId], references: [id])

  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}
